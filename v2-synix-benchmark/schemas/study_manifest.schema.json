{
  "description": "Top-level study definition.\n\nFixes the scope set, policy set, model choices, and code version\nfor a benchmark study. All runs and scores are tied back to this.",
  "properties": {
    "study_id": {
      "title": "Study Id",
      "type": "string"
    },
    "benchmark_version": {
      "default": "v2",
      "title": "Benchmark Version",
      "type": "string"
    },
    "scope_ids": {
      "items": {
        "type": "string"
      },
      "title": "Scope Ids",
      "type": "array"
    },
    "policy_ids": {
      "items": {
        "type": "string"
      },
      "title": "Policy Ids",
      "type": "array"
    },
    "agent_model": {
      "title": "Agent Model",
      "type": "string"
    },
    "judge_model": {
      "title": "Judge Model",
      "type": "string"
    },
    "embedding_model": {
      "title": "Embedding Model",
      "type": "string"
    },
    "prompt_set_version": {
      "title": "Prompt Set Version",
      "type": "string"
    },
    "scoring_version": {
      "title": "Scoring Version",
      "type": "string"
    },
    "code_sha": {
      "title": "Code Sha",
      "type": "string"
    },
    "synix_build_graph_hash": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Synix Build Graph Hash"
    },
    "artifact_family_set_version": {
      "title": "Artifact Family Set Version",
      "type": "string"
    },
    "random_seed_policy": {
      "default": "deterministic",
      "title": "Random Seed Policy",
      "type": "string"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "notes": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Notes"
    }
  },
  "required": [
    "study_id",
    "scope_ids",
    "policy_ids",
    "agent_model",
    "judge_model",
    "embedding_model",
    "prompt_set_version",
    "scoring_version",
    "code_sha",
    "artifact_family_set_version",
    "created_at"
  ],
  "title": "StudyManifest",
  "type": "object"
}
