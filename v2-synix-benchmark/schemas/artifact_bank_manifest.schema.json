{
  "$defs": {
    "BankStatus": {
      "enum": [
        "planned",
        "building",
        "built",
        "released",
        "failed"
      ],
      "title": "BankStatus",
      "type": "string"
    },
    "BuildCost": {
      "description": "Cost metrics captured during bank compilation.",
      "properties": {
        "wall_time_s": {
          "default": 0.0,
          "title": "Wall Time S",
          "type": "number"
        },
        "prompt_tokens": {
          "default": 0,
          "title": "Prompt Tokens",
          "type": "integer"
        },
        "completion_tokens": {
          "default": 0,
          "title": "Completion Tokens",
          "type": "integer"
        },
        "embed_tokens": {
          "default": 0,
          "title": "Embed Tokens",
          "type": "integer"
        },
        "estimated_cost_usd": {
          "default": 0.0,
          "title": "Estimated Cost Usd",
          "type": "number"
        }
      },
      "title": "BuildCost",
      "type": "object"
    }
  },
  "description": "Per scope x checkpoint compiled artifact bank.\n\nInvariant: no artifact in this bank may contain information from\nepisodes beyond max_episode_ordinal. This is enforced at build\ntime via prefix-valid snapshot projections (D010, D014).",
  "properties": {
    "bank_manifest_id": {
      "title": "Bank Manifest Id",
      "type": "string"
    },
    "study_id": {
      "title": "Study Id",
      "type": "string"
    },
    "scope_id": {
      "title": "Scope Id",
      "type": "string"
    },
    "checkpoint_id": {
      "title": "Checkpoint Id",
      "type": "string"
    },
    "max_episode_ordinal": {
      "title": "Max Episode Ordinal",
      "type": "integer"
    },
    "source_episode_ids": {
      "items": {
        "type": "string"
      },
      "title": "Source Episode Ids",
      "type": "array"
    },
    "artifact_families": {
      "additionalProperties": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "null"
          }
        ]
      },
      "title": "Artifact Families",
      "type": "object"
    },
    "dataset_hash": {
      "title": "Dataset Hash",
      "type": "string"
    },
    "synix_build_ref": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Synix Build Ref"
    },
    "synix_release_ref": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Synix Release Ref"
    },
    "synix_build_graph_hash": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Synix Build Graph Hash"
    },
    "status": {
      "$ref": "#/$defs/BankStatus",
      "default": "planned"
    },
    "built_at": {
      "anyOf": [
        {
          "format": "date-time",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Built At"
    },
    "build_cost": {
      "anyOf": [
        {
          "$ref": "#/$defs/BuildCost"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    }
  },
  "required": [
    "bank_manifest_id",
    "study_id",
    "scope_id",
    "checkpoint_id",
    "max_episode_ordinal",
    "source_episode_ids",
    "artifact_families",
    "dataset_hash"
  ],
  "title": "BankManifest",
  "type": "object"
}
