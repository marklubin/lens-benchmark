{
  "$defs": {
    "RunCost": {
      "description": "Cost metrics captured during a policy run.",
      "properties": {
        "wall_time_s": {
          "default": 0.0,
          "title": "Wall Time S",
          "type": "number"
        },
        "prompt_tokens": {
          "default": 0,
          "title": "Prompt Tokens",
          "type": "integer"
        },
        "completion_tokens": {
          "default": 0,
          "title": "Completion Tokens",
          "type": "integer"
        },
        "estimated_cost_usd": {
          "default": 0.0,
          "title": "Estimated Cost Usd",
          "type": "number"
        }
      },
      "title": "RunCost",
      "type": "object"
    },
    "RunStatus": {
      "enum": [
        "planned",
        "running",
        "completed",
        "failed",
        "resumed"
      ],
      "title": "RunStatus",
      "type": "string"
    }
  },
  "description": "Per scope x policy x replicate execution.\n\nLinks to the study, policy manifest, and the bank manifests\nused at each checkpoint. Tracks execution status and resume\nprogress.",
  "properties": {
    "run_id": {
      "title": "Run Id",
      "type": "string"
    },
    "study_id": {
      "title": "Study Id",
      "type": "string"
    },
    "scope_id": {
      "title": "Scope Id",
      "type": "string"
    },
    "policy_id": {
      "title": "Policy Id",
      "type": "string"
    },
    "replicate_id": {
      "title": "Replicate Id",
      "type": "string"
    },
    "policy_manifest_id": {
      "title": "Policy Manifest Id",
      "type": "string"
    },
    "bank_manifest_ids": {
      "items": {
        "type": "string"
      },
      "title": "Bank Manifest Ids",
      "type": "array"
    },
    "config_hash": {
      "title": "Config Hash",
      "type": "string"
    },
    "dataset_hash": {
      "title": "Dataset Hash",
      "type": "string"
    },
    "status": {
      "$ref": "#/$defs/RunStatus",
      "default": "planned"
    },
    "started_at": {
      "anyOf": [
        {
          "format": "date-time",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Started At"
    },
    "completed_at": {
      "anyOf": [
        {
          "format": "date-time",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Completed At"
    },
    "last_completed_checkpoint": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Last Completed Checkpoint"
    },
    "last_completed_question": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Last Completed Question"
    },
    "cost": {
      "anyOf": [
        {
          "$ref": "#/$defs/RunCost"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    }
  },
  "required": [
    "run_id",
    "study_id",
    "scope_id",
    "policy_id",
    "replicate_id",
    "policy_manifest_id",
    "bank_manifest_ids",
    "config_hash",
    "dataset_hash"
  ],
  "title": "RunManifest",
  "type": "object"
}
