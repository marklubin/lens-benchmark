{
  "$defs": {
    "EventType": {
      "enum": [
        "bank_build_started",
        "bank_build_completed",
        "bank_build_failed",
        "artifact_compiled",
        "run_started",
        "run_completed",
        "run_failed",
        "run_resumed",
        "checkpoint_started",
        "checkpoint_completed",
        "question_started",
        "question_completed",
        "model_call_completed",
        "scoring_started",
        "scoring_completed"
      ],
      "title": "EventType",
      "type": "string"
    }
  },
  "description": "Append-only event log entry.\n\nEvery significant action during bank compilation or policy\nexecution is recorded as an event. Events are the audit trail\nthat ties results back to manifests.",
  "properties": {
    "event_id": {
      "title": "Event Id",
      "type": "string"
    },
    "timestamp": {
      "format": "date-time",
      "title": "Timestamp",
      "type": "string"
    },
    "study_id": {
      "title": "Study Id",
      "type": "string"
    },
    "run_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Run Id"
    },
    "scope_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Scope Id"
    },
    "policy_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Policy Id"
    },
    "bank_manifest_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Bank Manifest Id"
    },
    "event_type": {
      "$ref": "#/$defs/EventType"
    },
    "attempt": {
      "anyOf": [
        {
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Attempt"
    },
    "config_hash": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Config Hash"
    },
    "input_refs": {
      "items": {
        "type": "string"
      },
      "title": "Input Refs",
      "type": "array"
    },
    "output_refs": {
      "items": {
        "type": "string"
      },
      "title": "Output Refs",
      "type": "array"
    },
    "payload": {
      "additionalProperties": true,
      "title": "Payload",
      "type": "object"
    },
    "error": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Error"
    }
  },
  "required": [
    "event_id",
    "timestamp",
    "study_id",
    "event_type"
  ],
  "title": "Event",
  "type": "object"
}
