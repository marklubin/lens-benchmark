    "policy_manifest_id": {
      "title": "Policy Manifest Id",
      "type": "string"
    },
    "policy_id": {
      "title": "Policy Id",
      "type": "string"
    },
    "visible_artifact_families": {
      "items": {
        "type": "string"
      },
      "title": "Visible Artifact Families",
      "type": "array"
    },
    "query_surfaces": {
      "items": {
        "type": "string"
      },
      "title": "Query Surfaces",
      "type": "array"
    },
    "fusion": {
