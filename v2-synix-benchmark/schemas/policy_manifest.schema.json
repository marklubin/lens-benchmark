          "additionalProperties": true,
          "type": "object"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Reduce Config"
    }
  },
  "required": [
    "policy_manifest_id",
    "policy_id",
    "visible_artifact_families",
    "query_surfaces",
